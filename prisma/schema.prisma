generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  VIEWER
  ANALYST
  ADMIN
}

enum RecordType {
  INCOME
  EXPENSE
}

model User {
  id        String            @id @default(uuid()) @map("_id")
  name      String
  email     String            @unique
  password  String
  role      Role              @default(VIEWER)
  isActive  Boolean           @default(true)
  createdAt DateTime          @default(now())
  records   FinancialRecord[]

  @@map("users")
}

model FinancialRecord {
  id        String      @id @default(uuid()) @map("_id")
  amount    Float
  type      RecordType
  category  String
  date      DateTime
  notes     String?
  deletedAt DateTime?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([category])
  @@index([date])
  @@index([deletedAt])
  @@map("financial_records")
}
