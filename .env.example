# Copy to .env and adjust values

# Server
PORT=8000
NODE_ENV=development

# MongoDB — local or Atlas (must start with mongodb:// or mongodb+srv://)
# Local: mongodb://127.0.0.1:27017/finance_dashboard
# Atlas: mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/finance_dashboard?retryWrites=true&w=majority
DATABASE_URL="mongodb://127.0.0.1:27017/finance_dashboard"

# JWT — use a long random string in production
JWT_SECRET="change-me-to-a-long-random-secret-for-development-only"
JWT_EXPIRES_IN="7d"
